# VERDICT runtime configuration
# Copy to .env if needed and replace the placeholders.

# X Layer testnet is currently exercised through the direct signer path.
# Switch to `onchainos` only on networks supported by `onchainos wallet contract-call`.
VERDICT_OPERATOR_MODE=private_key
VERDICT_DEPLOY_SIGNER_MODE=manual

# Only required when VERDICT_DEPLOY_SIGNER_MODE=private_key
# This is for Hardhat deployment, not for Agentic Wallet contract calls.
PRIVATE_KEY=REPLACE_WITH_YOUR_PRIVATE_KEY_WITHOUT_0x
OKX_API_KEY=REPLACE_WITH_OKX_API_KEY
OKLINK_API_KEY=REPLACE_WITH_OKLINK_API_KEY
ONCHAINOS_API_KEY=REPLACE_WITH_ONCHAINOS_API_KEY
ONCHAINOS_SECRET_KEY=REPLACE_WITH_ONCHAINOS_SECRET_KEY
ONCHAINOS_PASSPHRASE=REPLACE_WITH_ONCHAINOS_PASSPHRASE
MOLTBOOK_API_KEY=REPLACE_WITH_MOLTBOOK_API_KEY

VERDICT_NETWORK=xlayer_testnet
VERDICT_RPC_URL=https://testrpc.xlayer.tech
VERDICT_CORE_ADDRESS=

USDC_ADDRESS_TESTNET=REPLACE_WITH_VALID_TESTNET_ERC20_ADDRESS
USDC_ADDRESS_MAINNET=0x74b7F16337b8972027F6196A17a631aC6dE26d22
USDC_ADDRESS_LOCAL=

COUNTERPARTY_ADDRESS=REPLACE_WITH_COUNTERPARTY_WALLET
TARGET_ADDRESS=REPLACE_WITH_TARGET_WALLET
DEFAULT_TARGET_AMOUNT=1
DEFAULT_COLLATERAL_AMOUNT=0.5
DEFAULT_TOKEN_DECIMALS=6

GITHUB_REPO_URL=https://github.com/REPLACE_WITH_YOUR_REPO
DEPLOYED_DASHBOARD_URL=https://REPLACE_WITH_DASHBOARD_URL
CONTACT_EMAIL=REPLACE_WITH_CONTACT_EMAIL
CONTACT_TELEGRAM=@REPLACE_WITH_TELEGRAM
XLAYER_WALLET_ADDRESS=REPLACE_WITH_AGENTIC_WALLET_ADDRESS
X_POST_URL=https://x.com/REPLACE_WITH_BUILDX_POST

# Resolver subsystem
VERDICT_RESOLVER_DATABASE_URL=
VERDICT_RESOLVER_STATE_PATH=
VERDICT_RESOLVER_POLL_MS=30000
VERDICT_RESOLVER_CONFIRMATION_BUFFER_BLOCKS=1
VERDICT_RESOLVER_MAX_JOBS=10
VERDICT_RESOLVER_RETRY_BASE_MS=30000
VERDICT_RESOLVER_MAX_ATTEMPTS=8
VERDICT_RESOLVER_LEASE_MS=180000
VERDICT_RESOLVER_INDEX_CHUNK_SIZE=2000
VERDICT_RESOLVER_LOG_SIGNAL=false
VERDICT_RESOLVER_X402=false
VERDICT_TX_TRACK_TIMEOUT_MS=120000
